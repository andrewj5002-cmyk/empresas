<svg width="200" height="200" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200">
    <!-- Fondo del logo -->
    <rect width="200" height="200" fill="#1e3a8a" rx="20"/>
    
    <!-- Elemento decorativo superior -->
    <circle cx="100" cy="50" r="25" fill="#0ea5e9"/>
    
    <!-- Símbolo de tecnología - Circuitos -->
    <g stroke="#f59e0b" stroke-width="3" fill="none" stroke-linecap="round" stroke-linejoin="round">
        <!-- Línea superior */
        <path d="M 60 70 L 80 70"/>
        <circle cx="80" cy="70" r="4" fill="#f59e0b"/>
        
        <!-- Línea media -->
        <path d="M 50 100 L 100 100 L 150 100"/>
        <circle cx="50" cy="100" r="4" fill="#f59e0b"/>
        <circle cx="100" cy="100" r="4" fill="#f59e0b"/>
        <circle cx="150" cy="100" r="4" fill="#f59e0b"/>
        
        <!-- Línea inferior -->
        <path d="M 120 130 L 140 130"/>
        <circle cx="140" cy="130" r="4" fill="#f59e0b"/>
        
        <!-- Conexiones verticales -->
        <line x1="80" y1="70" x2="80" y2="85"/>
        <line x1="100" y1="85" x2="100" y2="100"/>
        <line x1="150" y1="100" x2="150" y2="115"/>
        <line x1="140" y1="115" x2="140" y2="130"/>
    </g>
    
    <!-- Nombre de la empresa -->
    <text x="100" y="165" font-family="Arial, sans-serif" font-size="28" font-weight="bold" fill="#ffffff" text-anchor="middle">TechHub</text>
    
    <!-- Texto decorativo -->
    <text x="100" y="185" font-family="Arial, sans-serif" font-size="10" fill="#0ea5e9" text-anchor="middle" letter-spacing="2">SOLUTIONS</text>
</svg>
